{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of tracked services not currently active.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(node_systemd_unit_state{state=\"active\", name=~\"(actual|jellyfin|mealie|postgresql|qbittorrent|sabnzbd|nginx|mullvad|prometheus|prometheus-node-exporter|alertmanager|grafana|libvirtd|paperless-.+|samba-.+)\\\\.service\"} == 0) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Services down",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "active state of each long-running service unit, per host.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true, "inspect": false },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Down", "color": "red", "index": 0 },
                "1": { "text": "Up", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Host" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          }
        ]
      },
      "gridPos": { "h": 18, "w": 18, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Status", "desc": false }]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_systemd_unit_state{state=\"active\", name=~\"(actual|jellyfin|mealie|postgresql|qbittorrent|sabnzbd|nginx|mullvad|prometheus|prometheus-node-exporter|alertmanager|grafana|libvirtd|paperless-.+|samba-.+)\\\\.service\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Service status",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "job": true, "state": true, "__name__": true, "instance": false },
            "indexByName": { "name": 0, "instance": 1, "Value": 2 },
            "renameByName": { "name": "Service", "instance": "Host", "Value": "Status" }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Result of the most recent restic run per job (failed state of the oneshot service).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": false, "inspect": false },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OK", "color": "green", "index": 0 },
                "1": { "text": "Failed", "color": "red", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Last result" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "custom.width", "value": 110 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 9, "x": 0, "y": 18 },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Last result", "desc": true }]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_systemd_unit_state{state=\"failed\", name=~\"restic-backups-.+\\\\.service\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Last backup result",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "job": true, "state": true, "__name__": true },
            "indexByName": { "name": 0, "instance": 1, "Value": 2 },
            "renameByName": { "name": "Backup", "instance": "Host", "Value": "Last result" }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Time since each backup last ran (red if a daily job hasn't run in 26h).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": false, "inspect": false },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 93600 }
            ]
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Last run" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "custom.width", "value": 140 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 9, "x": 9, "y": 18 },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Last run", "desc": true }]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "time() - node_systemd_timer_last_trigger_seconds{name=~\"restic-backups-.+\\\\.timer\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Last backup run",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "job": true, "__name__": true },
            "indexByName": { "name": 0, "instance": 1, "Value": 2 },
            "renameByName": { "name": "Backup", "instance": "Host", "Value": "Last run" }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["homelab", "services"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Australia/Sydney",
  "title": "Service status",
  "uid": "homelab-services",
  "version": 1,
  "weekStart": ""
}
