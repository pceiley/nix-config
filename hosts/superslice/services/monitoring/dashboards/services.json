        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_systemd_unit_state{state=\"active\", name=~\"(actual|jellyfin|mealie|postgresql|qbittorrent|sabnzbd|nginx|mullvad|prometheus|prometheus-node-exporter|alertmanager|grafana|libvirtd|paperless-.+|samba-.+)\\\\.service\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Service status",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "state": true,
              "__name__": true,
              "instance": false
            },
            "indexByName": {
              "name": 0,
              "instance": 1,
              "Value": 2
            },
            "renameByName": {
              "name": "Service",
              "instance": "Host",
              "Value": "Status"
            }
          }
        }
      ],
      "type": "table"
    },
