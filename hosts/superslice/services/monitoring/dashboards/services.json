      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (backup, instance) (label_replace(node_systemd_unit_state{state=\"failed\", name=~\"restic-backups-.+\\.service\"}, \"backup\", \"$1\", \"name\", \"restic-backups-(.+)\\\\.service\"))",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (backup) (label_replace(time() - node_systemd_timer_last_trigger_seconds{name=~\"restic-backups-.+\\.timer\"}, \"backup\", \"$1\", \"name\", \"restic-backups-(.+)\\.timer\"))",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "title": "Backups",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "backup",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true
            },
            "indexByName": {
              "backup": 0,
              "instance": 1,
              "Value #A": 2,
              "Value #B": 3
            },
            "renameByName": {
              "backup": "Backup",
              "instance": "Host",
              "Value #A": "Last result",
              "Value #B": "Last run"
            }
          }
        }
      ],
      "type": "table"
